{
  "name": "carvion-prototipo",
  "version": "0.2.0",
  "private": true,
  "description": "CARVION, plataforma inteligente de gestão empresarial.",
  "scripts": {
    "dev:prototype": "serve -l 3000 .",
    "serve:static": "serve -l ${PORT:-3000} .",
    "start": "npm start --prefix backend",
    "build:full": "npm install --prefix backend && npm run db:generate --prefix backend && npm run build --prefix backend",
    "start:full": "npm start --prefix backend",
    "dev:api": "npm run dev --prefix backend",
    "db:generate": "npm run db:generate --prefix backend",
    "db:migrate": "npm run db:migrate --prefix backend",
    "db:seed": "npm run db:seed --prefix backend"
  },
  "dependencies": {
    "serve": "^14.2.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5"
  }
}
