generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  GESTOR
  OPERADOR
  REPRESENTANTE
  FINANCEIRO
}

enum ProductionStatus {
  PLANEJADO
  EM_PRODUCAO
  FINALIZADO
  CANCELADO
}

enum StepName {
  CORTE
  COSTURA
  MONTAGEM
  ACABAMENTO
}

enum SaleStatus {
  ORCAMENTO
  APROVADO
  EM_PRODUCAO
  FATURADO
  ENTREGUE
}

model Company {
  id        String   @id @default(cuid())
  name      String
  taxId     String
  users     User[]
  products  Product[]
  materials Material[]
  orders    ProductionOrder[]
  sales     Sale[]
  reps      Representative[]
  employees Employee[]
  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  company      Company  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String   @unique
  passwordHash String
  role         RoleName
  createdAt    DateTime @default(now())

  @@index([tenantId, role])
}

model Product {
  id          String         @id @default(cuid())
  tenantId    String
  company     Company        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  ballType    String
  imageUrl    String?
  technical   String
  salePrice   Decimal        @db.Decimal(10, 2)
  bomItems    BomItem[]
  stockLots   FinishedStock[]
  orders      ProductionOrder[]

  @@index([tenantId, ballType])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  createdAt DateTime @default(now())
}

model Material {
  id        String    @id @default(cuid())
  tenantId  String
  company   Company   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sku       String
  name      String
  unit      String
  stock     Decimal   @db.Decimal(12, 3)
  minStock  Decimal   @db.Decimal(12, 3)
  unitCost  Decimal   @db.Decimal(10, 2)
  bomItems  BomItem[]
  usages    MaterialUsage[]

  @@unique([tenantId, sku])
  @@index([tenantId, stock])
}

model BomItem {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Decimal  @db.Decimal(12, 4)
}

model ProductionOrder {
  id            String             @id @default(cuid())
  tenantId      String
  company       Company            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId     String
  product       Product            @relation(fields: [productId], references: [id])
  saleId        String?
  quantity      Int
  status        ProductionStatus   @default(PLANEJADO)
  estimatedCost Decimal            @db.Decimal(12, 2)
  realCost      Decimal            @db.Decimal(12, 2) @default(0)
  wasteRate     Decimal            @db.Decimal(5, 2) @default(0)
  steps         ProductionStep[]
  materialUsage MaterialUsage[]
  createdAt     DateTime           @default(now())

  @@index([tenantId, status, createdAt])
}

model ProductionStep {
  id          String          @id @default(cuid())
  orderId     String
  order       ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name        StepName
  employeeId  String?
  startedAt   DateTime?
  finishedAt  DateTime?
  laborHours  Decimal         @db.Decimal(8, 2) @default(0)
  laborCost   Decimal         @db.Decimal(10, 2) @default(0)
  producedQty Int             @default(0)
}

model MaterialUsage {
  id         String          @id @default(cuid())
  orderId    String
  order      ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  materialId String
  material   Material        @relation(fields: [materialId], references: [id])
  quantity   Decimal         @db.Decimal(12, 3)
  cost       Decimal         @db.Decimal(12, 2)
  wasteQty   Decimal         @db.Decimal(12, 3) @default(0)
}

model Employee {
  id          String   @id @default(cuid())
  tenantId    String
  company     Company  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  role        String
  hourlyCost  Decimal  @db.Decimal(10, 2)
  pieceCost   Decimal? @db.Decimal(10, 2)
}

model Representative {
  id             String   @id @default(cuid())
  tenantId       String
  company        Company  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  region         String
  commissionRate Decimal  @db.Decimal(5, 2)
  monthlyGoal    Decimal  @db.Decimal(12, 2)
  sales          Sale[]

  @@index([tenantId, region])
}

model Customer {
  id        String @id @default(cuid())
  tenantId  String
  name      String
  city      String
  segment   String
  sales     Sale[]
}

model Sale {
  id               String         @id @default(cuid())
  tenantId         String
  company          Company        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId       String
  customer         Customer       @relation(fields: [customerId], references: [id])
  representativeId String
  representative   Representative @relation(fields: [representativeId], references: [id])
  status           SaleStatus      @default(ORCAMENTO)
  total            Decimal         @db.Decimal(12, 2)
  commission       Decimal         @db.Decimal(12, 2)
  createdAt        DateTime        @default(now())

  @@index([tenantId, status, createdAt])
}

model FinishedStock {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  lotCode   String
  quantity  Int
  unitCost  Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
}

model Transaction {
  id          String   @id @default(cuid())
  tenantId    String
  type        String
  category    String
  description String
  amount      Decimal  @db.Decimal(12, 2)
  dueDate     DateTime
  paidAt      DateTime?
}
